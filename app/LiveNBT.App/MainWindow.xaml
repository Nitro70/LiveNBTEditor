<Window x:Class="LiveNBT.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LiveNBT.App.ViewModels"
        xmlns:local="clr-namespace:LiveNBT.App"
        Title="LiveNBT" Height="700" Width="1330" MinHeight="440" MinWidth="900"
        Background="{StaticResource Bg0Brush}" Foreground="{StaticResource TextPrimaryBrush}"
        Closing="OnWindowClosing" PreviewKeyDown="OnWindowKeyDown">
    <Window.Resources>
        <local:TypeChipBrushConverter x:Key="TypeChipBrush"/>
    </Window.Resources>
    <DockPanel>
        <!-- ===== header bar ===== -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Bg1Brush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1" Padding="10,8">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="LiveNBT" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="2,0,14,0"/>

                    <Button Content="⚡ Attach to Minecraft" Style="{StaticResource AccentButton}" Click="OnAttach"
                            MinWidth="150"
                            ToolTip="Load LiveNBT into the running game with no launch arguments, then connect"/>

                    <Border Style="{StaticResource ToolbarDivider}"/>

                    <ComboBox x:Name="ProfileBox" Width="140" VerticalAlignment="Center"
                              ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                              DisplayMemberPath="Name" ToolTip="Connection profile (for remote / manual connect)"/>
                    <Button Content="Profiles…" Click="OnEditProfiles" Margin="6,0,0,0"/>

                    <Button Content="Connect" Click="OnConnect" Margin="8,0,0,0" MinWidth="76"/>
                    <Button Content="Disconnect" Click="OnDisconnect" Margin="6,0,0,0"/>

                    <Ellipse Width="9" Height="9" Margin="12,0,0,0" VerticalAlignment="Center"
                             ToolTip="Connection status">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#FF5A6472"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <Border Style="{StaticResource ToolbarDivider}"/>

                    <ComboBox Width="205" VerticalAlignment="Center"
                              ItemsSource="{Binding Roots}" SelectedItem="{Binding SelectedRoot}"
                              ToolTip="What to edit: a player, a world, or an inventory"/>
                    <Button Content="Load" Click="OnLoadRoot" Margin="6,0,0,0"/>
                    <Button Content="⟳" Click="OnRefreshRoots" Margin="4,0,0,0" ToolTip="Refresh the list of players and worlds"/>

                    <Border Style="{StaticResource ToolbarDivider}"/>

                    <Button Content="🎒 Inventory" Click="OnOpenInventory" ToolTip="Open the inventory editor (Ctrl+I)"/>
                </StackPanel>

                <Button DockPanel.Dock="Right" Content="❔ Help" Click="OnOpenHelp" Margin="10,0,0,0"
                        ToolTip="How to use LiveNBT + all keyboard shortcuts (F1)"/>

                <!-- filter, right-aligned; the left margin keeps it clear of the toolbar buttons -->
                <Grid DockPanel.Dock="Right" Width="160" Margin="18,0,0,0" VerticalAlignment="Center">
                    <TextBox x:Name="FilterBox"
                             Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             TextChanged="OnFilterChanged"/>
                    <TextBlock Text="Filter tags  (Ctrl+F)" Margin="9,0,0,0" VerticalAlignment="Center"
                               Foreground="{StaticResource TextDisabledBrush}" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=FilterBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ===== status bar ===== -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="{Binding Status}"/>
        </StatusBar>

        <!-- ===== watches ===== -->
        <GroupBox DockPanel.Dock="Right" Header="WATCHES" Width="280" Margin="0,10,10,10">
            <ListBox ItemsSource="{Binding Watches}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel Margin="2" Background="Transparent"
                                   MouseLeftButtonDown="OnWatchRowClick"
                                   ToolTip="Double-click to jump to this tag in the tree">
                            <Button DockPanel.Dock="Right" Content="✕" Padding="4,0" Margin="4,0,0,0"
                                    VerticalAlignment="Top" Click="OnRemoveWatch"
                                    ToolTip="Stop watching"/>
                            <StackPanel>
                                <TextBlock Text="{Binding Display}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding ValueText}" FontFamily="Consolas" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- ===== the NBT tree ===== -->
        <Border Margin="10" Background="{StaticResource Bg1Brush}" BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1" CornerRadius="6">
            <TreeView x:Name="Tree" Margin="4" PreviewMouseWheel="OnTreeWheel">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.Resources>
                    <HierarchicalDataTemplate DataType="{x:Type vm:NodeViewModel}" ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal"
                                    MouseLeftButtonDown="OnNodeDoubleClick"
                                    Background="Transparent"
                                    ToolTip="{Binding ToolTipText}">
                            <StackPanel.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Edit value  (Enter)" Click="OnEditMenu" IsEnabled="{Binding CanEdit}"/>
                                    <MenuItem Header="Edit as SNBT…  (Ctrl+Shift+E)" Click="OnEditSnbtMenu" IsEnabled="{Binding CanEditSnbt}"/>
                                    <MenuItem Header="Watch / Unwatch" Click="OnWatchMenu"/>
                                    <Separator/>
                                    <MenuItem Header="Add tag…" Click="OnAddMenu" IsEnabled="{Binding CanAddChild}"/>
                                    <MenuItem Header="Quick add" IsEnabled="{Binding CanAddChild}">
                                        <MenuItem Header="Byte" Tag="byte" Click="OnQuickAddMenu"/>
                                        <MenuItem Header="Short" Tag="short" Click="OnQuickAddMenu"/>
                                        <MenuItem Header="Int" Tag="int" Click="OnQuickAddMenu"/>
                                        <MenuItem Header="Long" Tag="long" Click="OnQuickAddMenu"/>
                                        <MenuItem Header="Float" Tag="float" Click="OnQuickAddMenu"/>
                                        <MenuItem Header="Double" Tag="double" Click="OnQuickAddMenu"/>
                                        <MenuItem Header="String" Tag="string" Click="OnQuickAddMenu"/>
                                        <MenuItem Header="Compound" Tag="compound" Click="OnQuickAddMenu"/>
                                        <MenuItem Header="List" Tag="list" Click="OnQuickAddMenu"/>
                                    </MenuItem>
                                    <MenuItem Header="Add as SNBT…" Click="OnAddSnbtMenu" IsEnabled="{Binding CanAddChild}"/>
                                    <MenuItem Header="Paste tag(s)  (Ctrl+V)" Click="OnPasteMenu" IsEnabled="{Binding CanAddChild}"/>
                                    <MenuItem Header="Duplicate  (Ctrl+D)" Click="OnDuplicateMenu" IsEnabled="{Binding CanDuplicate}"/>
                                    <MenuItem Header="Rename…  (F2)" Click="OnRenameMenu" IsEnabled="{Binding CanRename}"/>
                                    <Separator/>
                                    <MenuItem Header="Move up  (Alt+Up)" Click="OnMoveUpMenu" IsEnabled="{Binding CanMove}"/>
                                    <MenuItem Header="Move down  (Alt+Down)" Click="OnMoveDownMenu" IsEnabled="{Binding CanMove}"/>
                                    <Separator/>
                                    <MenuItem Header="Cut  (Ctrl+X)" Click="OnCutMenu" IsEnabled="{Binding CanDelete}"/>
                                    <MenuItem Header="Copy as SNBT  (Ctrl+C)" Click="OnCopySnbtMenu"/>
                                    <MenuItem Header="Copy path  (Ctrl+Shift+C)" Click="OnCopyPathMenu"/>
                                    <Separator/>
                                    <MenuItem Header="Delete  (Del)" Click="OnDeleteMenu" IsEnabled="{Binding CanDelete}"/>
                                </ContextMenu>
                            </StackPanel.ContextMenu>
                            <Border MinWidth="26" Margin="0,0,6,0" CornerRadius="3" Padding="3,0"
                                    Background="{Binding Type, Converter={StaticResource TypeChipBrush}}">
                                <TextBlock Text="{Binding TypeGlyph}" HorizontalAlignment="Center" FontFamily="Consolas"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Border>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Margin="0,0,6,0"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="⚠ changed" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ConflictHint}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- value: text normally, editor while IsEditing -->
                            <TextBlock Text="{Binding ValueText}" FontFamily="Consolas"
                                       Foreground="{StaticResource TextSecondaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Flash}" Value="ok">
                                                <Setter Property="Background" Value="{StaticResource FlashOkBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Flash}" Value="error">
                                                <Setter Property="Background" Value="{StaticResource FlashErrorBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox MinWidth="120" FontFamily="Consolas"
                                     KeyDown="OnEditorKeyDown" LostFocus="OnEditorLostFocus"
                                     IsVisibleChanged="OnEditorIsVisibleChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="Padding" Value="4,1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.Resources>
            </TreeView>
        </Border>
    </DockPanel>
</Window>
