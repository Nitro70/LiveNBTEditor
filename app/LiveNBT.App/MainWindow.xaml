<Window x:Class="LiveNBT.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LiveNBT.App.ViewModels"
        Title="LiveNBT" Height="650" Width="980" Closing="OnWindowClosing">
    <DockPanel>
        <!-- toolbar -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <ComboBox x:Name="ProfileBox" Width="160" ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding SelectedProfile}" DisplayMemberPath="Name"/>
                <Button Content="Profiles…" Click="OnEditProfiles"/>
                <Separator/>
                <Button Content="Connect" Click="OnConnect"/>
                <Button Content="Disconnect" Click="OnDisconnect"/>
                <Ellipse Width="10" Height="10" Margin="6,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="IndianRed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="MediumSeaGreen"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <Separator/>
                <ComboBox Width="220" ItemsSource="{Binding Roots}" SelectedItem="{Binding SelectedRoot}"/>
                <Button Content="Load" Click="OnLoadRoot"/>
                <Button Content="⟳ Roots" Click="OnRefreshRoots"/>
                <Separator/>
                <TextBox Width="180"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         TextChanged="OnFilterChanged" ToolTip="Filter top-level branches by tag name"/>
            </ToolBar>
        </ToolBarTray>

        <!-- status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="{Binding Status}"/>
        </StatusBar>

        <!-- watch panel -->
        <GroupBox DockPanel.Dock="Right" Header="Watches" Width="280">
            <ListBox ItemsSource="{Binding Watches}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2">
                            <TextBlock Text="{Binding Display}" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding ValueText}" FontFamily="Consolas" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- the tree (ItemsSource assigned in code-behind when TreeRoot changes) -->
        <TreeView x:Name="Tree">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type vm:NodeViewModel}" ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal"
                                MouseLeftButtonDown="OnNodeDoubleClick"
                                Background="Transparent">
                        <StackPanel.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Edit value" Click="OnEditMenu"/>
                                <MenuItem Header="Watch / Unwatch" Click="OnWatchMenu"/>
                                <Separator/>
                                <MenuItem Header="Add tag…" Click="OnAddMenu"/>
                                <MenuItem Header="Delete" Click="OnDeleteMenu"/>
                                <Separator/>
                                <MenuItem Header="Copy path" Click="OnCopyPathMenu"/>
                                <MenuItem Header="Copy as SNBT" Click="OnCopySnbtMenu"/>
                            </ContextMenu>
                        </StackPanel.ContextMenu>
                        <Border Width="26" Margin="0,0,4,0" Background="#33808080" CornerRadius="3">
                            <TextBlock Text="{Binding TypeGlyph}" HorizontalAlignment="Center" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Margin="0,0,6,0"/>
                        <TextBlock Text="⚠ changed" Foreground="DarkOrange" Margin="0,0,6,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConflictHint}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- value: text normally, editor while IsEditing -->
                        <TextBlock Text="{Binding ValueText}" FontFamily="Consolas">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Flash}" Value="ok">
                                            <Setter Property="Background" Value="#5532CD32"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Flash}" Value="error">
                                            <Setter Property="Background" Value="#55DC143C"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox MinWidth="120" FontFamily="Consolas"
                                 KeyDown="OnEditorKeyDown" LostFocus="OnEditorLostFocus"
                                 IsVisibleChanged="OnEditorIsVisibleChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.Resources>
        </TreeView>
    </DockPanel>
</Window>
