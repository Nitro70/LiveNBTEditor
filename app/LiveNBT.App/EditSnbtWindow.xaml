<Window x:Class="LiveNBT.App.EditSnbtWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit as SNBT" Height="420" Width="560" MinHeight="260" MinWidth="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg0Brush}" Foreground="{StaticResource TextPrimaryBrush}"
        PreviewKeyDown="OnWindowKeyDown">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="SnbtBox" AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas"
                 TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto" VerticalContentAlignment="Top"/>

        <TextBlock x:Name="ErrorText" Grid.Row="1" Margin="0,8,0,0" TextWrapping="Wrap"
                   Foreground="#FFE08C8C" Visibility="Collapsed"/>

        <DockPanel Grid.Row="2" Margin="0,10,0,0" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                       Foreground="{StaticResource TextDisabledBrush}"
                       Text="Ctrl+Enter to apply — the whole subtree is replaced live"/>
            <Button DockPanel.Dock="Right" Content="Cancel" Width="70" IsCancel="True"/>
            <Button DockPanel.Dock="Right" Content="Apply" Width="80" Margin="0,0,8,0" Click="OnApply"/>
        </DockPanel>
    </Grid>
</Window>
