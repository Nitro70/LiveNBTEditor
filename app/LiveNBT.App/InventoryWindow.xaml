<Window x:Class="LiveNBT.App.InventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LiveNBT.App"
        Title="Inventory Editor" Height="560" Width="800" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <DataTemplate x:Key="SlotTemplate">
            <Button Width="50" Height="50" Margin="1" Tag="{Binding}" Click="OnSlotClick" ToolTip="{Binding ItemId}">
                <StackPanel>
                    <TextBlock Text="{Binding ItemId, Converter={x:Static local:ShortIdConverter.Instance}}"
                               FontSize="9" TextAlignment="Center" TextWrapping="Wrap" MaxHeight="28"/>
                    <TextBlock Text="{Binding Count}" FontSize="9" HorizontalAlignment="Right"/>
                </StackPanel>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <DockPanel Margin="8">
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="{Binding Status}"/>
        </StatusBar>
        <CheckBox DockPanel.Dock="Top" x:Name="LiveRefreshBox" Content="&#x27F3; Live refresh" IsChecked="True" Margin="2,2,2,8"/>

        <Border DockPanel.Dock="Right" Width="290" Margin="8,0,0,0" Padding="10"
                BorderBrush="#CCC" BorderThickness="1" CornerRadius="4">
            <StackPanel DataContext="{Binding SelectedSlot}">
                <TextBlock Text="{Binding SlotNumber, StringFormat='Slot {0}'}" FontWeight="Bold" FontSize="14"/>

                <TextBlock Text="Item" Margin="0,10,0,2" Foreground="#888"/>
                <local:SearchBox x:Name="ItemBox"
                                 Text="{Binding ItemId, Mode=TwoWay}"
                                 Suggestions="{Binding ItemIds, RelativeSource={RelativeSource AncestorType=Window}}"/>

                <TextBlock Text="Count (max 99)" Margin="0,10,0,2" Foreground="#888"/>
                <TextBox Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Enchantments" Margin="0,10,0,2" Foreground="#888"/>
                <ItemsControl ItemsSource="{Binding Enchantments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="48"/><ColumnDefinition Width="26"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Id}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="1" Text="{Binding Level}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Content="&#x2715;" Tag="{Binding}" Click="OnRemoveEnchant"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <DockPanel Margin="0,6,0,0">
                    <TextBox DockPanel.Dock="Right" x:Name="EnchLevelBox" Width="44" Text="1"/>
                    <local:SearchBox x:Name="EnchBox"
                                     Suggestions="{Binding EnchantmentIds, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </DockPanel>
                <Button Content="&#xFF0B; Add enchantment" Margin="0,4,0,0" Click="OnAddEnchant"/>

                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Apply" Width="80" Margin="0,0,8,0" Click="OnApply"/>
                    <Button Content="Clear slot" Width="90" Click="OnClear"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel>
            <TextBlock Text="Armor / Offhand" Foreground="#888" Margin="2,0,0,2"/>
            <StackPanel Orientation="Horizontal">
                <ItemsControl ItemsSource="{Binding Armor}" ItemTemplate="{StaticResource SlotTemplate}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding Offhand}" ItemTemplate="{StaticResource SlotTemplate}" Margin="16,0,0,0">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>

            <TextBlock Text="Main" Foreground="#888" Margin="2,10,0,2"/>
            <ItemsControl ItemsSource="{Binding Main}" ItemTemplate="{StaticResource SlotTemplate}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="9"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            </ItemsControl>

            <TextBlock Text="Hotbar" Foreground="#888" Margin="2,10,0,2"/>
            <ItemsControl ItemsSource="{Binding Hotbar}" ItemTemplate="{StaticResource SlotTemplate}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="9"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>
    </DockPanel>
</Window>
