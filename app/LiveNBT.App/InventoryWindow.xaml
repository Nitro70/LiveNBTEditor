<Window x:Class="LiveNBT.App.InventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LiveNBT.App"
        Title="Inventory Editor" Height="600" Width="860" WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg0Brush}" Foreground="{StaticResource TextPrimaryBrush}">
    <Window.Resources>
        <DataTemplate x:Key="SlotTemplate">
            <Button Tag="{Binding}" Click="OnSlotClick">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SlotButton}">
                        <Setter Property="ToolTip" Value="{Binding ItemId}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                <Setter Property="ToolTip" Value="{x:Null}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Grid>
                    <TextBlock Text="{Binding ItemId, Converter={x:Static local:ShortIdConverter.Instance}}"
                               FontSize="9" TextAlignment="Center" TextWrapping="Wrap" MaxHeight="30"
                               VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding Count}" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <DockPanel Margin="10">
        <StatusBar DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <StatusBarItem Content="{Binding Status}"/>
        </StatusBar>
        <CheckBox DockPanel.Dock="Top" x:Name="LiveRefreshBox" Content="Live refresh" IsChecked="True" Margin="2,0,2,10"/>

        <!-- ===== slot editor panel ===== -->
        <Border DockPanel.Dock="Right" Width="300" Margin="10,0,0,0" Padding="14"
                Background="{StaticResource Bg1Brush}" BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1" CornerRadius="6">
            <StackPanel DataContext="{Binding SelectedSlot}">
                <TextBlock Text="{Binding SlotNumber, StringFormat='Slot {0}'}" FontWeight="Bold" FontSize="14"
                           Foreground="{StaticResource TextPrimaryBrush}"/>

                <TextBlock Text="ITEM" Margin="0,12,0,3" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <!-- Suggestions must reach the WINDOW's view-model (this panel's DataContext is the slot) -->
                <local:SearchBox x:Name="ItemBox"
                                 Text="{Binding ItemId, Mode=TwoWay}"
                                 Suggestions="{Binding DataContext.ItemIds, RelativeSource={RelativeSource AncestorType=Window}}"/>

                <TextBlock Text="COUNT (1–99)" Margin="0,12,0,3" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}" Width="80" HorizontalAlignment="Left"/>

                <TextBlock Text="ENCHANTMENTS" Margin="0,14,0,3" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <ItemsControl ItemsSource="{Binding Enchantments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="50"/><ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Id}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Level}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <Button Grid.Column="2" Content="✕" Padding="4,1" Tag="{Binding}" Click="OnRemoveEnchant"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <DockPanel Margin="0,6,0,0">
                    <TextBox DockPanel.Dock="Right" x:Name="EnchLevelBox" Width="62" Text="1" Margin="6,0,0,0"
                             TextAlignment="Center" MaxLength="3" ToolTip="Level (1–255)"/>
                    <local:SearchBox x:Name="EnchBox"
                                     Suggestions="{Binding DataContext.EnchantmentIds, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </DockPanel>
                <Button Content="＋ Add enchantment" Margin="0,6,0,0" Click="OnAddEnchant"/>

                <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                    <Button Content="Apply" Style="{StaticResource AccentButton}" Width="88" Margin="0,0,8,0" Click="OnApply"/>
                    <Button Content="Clear slot" Width="90" Click="OnClear"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ===== the 41-slot grid ===== -->
        <StackPanel>
            <TextBlock Text="ARMOR / OFFHAND" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0,0,3"/>
            <StackPanel Orientation="Horizontal">
                <ItemsControl ItemsSource="{Binding Armor}" ItemTemplate="{StaticResource SlotTemplate}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding Offhand}" ItemTemplate="{StaticResource SlotTemplate}" Margin="18,0,0,0">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>

            <TextBlock Text="MAIN" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="4,12,0,3"/>
            <ItemsControl ItemsSource="{Binding Main}" ItemTemplate="{StaticResource SlotTemplate}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="9"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            </ItemsControl>

            <TextBlock Text="HOTBAR" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="4,12,0,3"/>
            <ItemsControl ItemsSource="{Binding Hotbar}" ItemTemplate="{StaticResource SlotTemplate}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="9"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>
    </DockPanel>
</Window>
