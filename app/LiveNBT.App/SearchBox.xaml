<UserControl x:Class="LiveNBT.App.SearchBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <TextBox x:Name="Input"
                 TextChanged="OnInputTextChanged"
                 PreviewKeyDown="OnInputKeyDown"
                 GotKeyboardFocus="OnInputGotFocus"
                 LostKeyboardFocus="OnInputLostFocus"/>
        <Popup x:Name="Pop" StaysOpen="False" Focusable="False"
               PlacementTarget="{Binding ElementName=Input}" Placement="Bottom"
               Width="{Binding ActualWidth, ElementName=Input}"
               AllowsTransparency="True">
            <Border Background="{StaticResource Bg1Brush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Margin="0,3,0,0" SnapsToDevicePixels="True">
                <ListBox x:Name="List" MaxHeight="220"
                         MouseLeftButtonUp="OnListClick"
                         PreviewKeyDown="OnListKeyDown"/>
            </Border>
        </Popup>
    </Grid>
</UserControl>
