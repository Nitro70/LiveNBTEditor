<Window x:Class="LiveNBT.App.ProfilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connection Profiles" Height="440" Width="600" WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg0Brush}" Foreground="{StaticResource TextPrimaryBrush}"
        ResizeMode="NoResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="185"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- profile list -->
        <Border Background="{StaticResource Bg1Brush}" BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,0,12,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4,6,4,2">
                    <Button Content="＋ Add" Click="OnAdd" MinWidth="62"/>
                    <Button Content="✕ Remove" Click="OnRemove" Margin="6,0,0,0" MinWidth="70"/>
                </StackPanel>
                <ListBox x:Name="ProfileList" DisplayMemberPath="Name" SelectionChanged="OnSelectionChanged"/>
            </DockPanel>
        </Border>

        <!-- editor form -->
        <Border Grid.Column="1" Background="{StaticResource Bg1Brush}" BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1" CornerRadius="6" Padding="14">
            <Grid x:Name="Form">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="58"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Name" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Grid.Column="1" Margin="0,3" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="1" Text="Host" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,3" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="2" Text="Port" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,3" Width="90" HorizontalAlignment="Left"
                         Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="3" Text="Token" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,3" FontFamily="Consolas"
                         Text="{Binding Token, UpdateSourceTrigger=PropertyChanged}"/>

                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Detect from this PC's game" Click="OnDetect"
                            ToolTip="Reads .minecraft\config\livenbt.json and fills in the host, port and token"/>
                    <Button Content="Open config folder" Click="OnOpenConfigFolder" Margin="8,0,0,0"/>
                </StackPanel>

                <TextBlock x:Name="DetectStatus" Grid.Row="5" Grid.Column="1" Margin="0,10,0,0" TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Top"
                           Text="Remote server? Host = the server's IP; token is in config/livenbt.json next to the server (Detect is for this PC's game only)."/>
            </Grid>
        </Border>

        <!-- app behavior options -->
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="2,12,0,0">
            <CheckBox x:Name="AutoConnectBox" Content="Connect automatically when the app starts"/>
            <CheckBox x:Name="AutoReconnectBox" Content="Reconnect automatically if the connection drops" Margin="22,0,0,0"/>
        </StackPanel>

        <!-- dialog buttons -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Save" Style="{StaticResource AccentButton}" MinWidth="86" Click="OnSave" IsDefault="True"/>
            <Button Content="Cancel" MinWidth="86" Margin="8,0,0,0" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
